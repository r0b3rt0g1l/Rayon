# Web3Forms — access key para los formularios de contacto y solicitud de
# información pública. Es pública (se usa en el cliente) → va con NEXT_PUBLIC_.
# Los formularios (ContactoForm / InformacionPublicaForm) la leen desde aquí; sin
# ella el formulario muestra "disponible en breve" y NO intenta enviar.
# Generar en https://web3forms.com y pegar aquí (y en Vercel).
NEXT_PUBLIC_WEB3FORMS_KEY=

# Slug del municipio que representa este sitio. Lo consume lib/content/cms.ts para
# armar los endpoints /api/municipios/<slug>/... Cambia este valor por municipio.
NEXT_PUBLIC_MUNICIPIO_SLUG=baviacora

# URL canónica del sitio (usada por sitemap, robots y SEO).
NEXT_PUBLIC_SITE_URL=https://baviacora.gob.mx

# Backend CMS. Lo consume lib/content/cms.ts para hero, noticias, imágenes,
# documentos, SEvAC y cabildo. En local apunta a http://localhost:3000 si tienes
# el backend levantado. Déjalo vacío para usar solo los fallbacks estáticos.
NEXT_PUBLIC_API_URL=
